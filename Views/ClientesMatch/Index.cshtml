@{
    ViewData["Title"] = "Clientes Match";
}

<link rel="stylesheet" href="~/css/clientesmatch.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

<div class="container-fluid match-module" style="background-color: #121212; min-height: 100vh; padding: 16px;">
    <div class="row mb-3">
        <div class="col-12">
            <h2 class="module-title mb-0">
                <i class="fas fa-handshake"></i> Clientes Match
            </h2>
            <p class="module-subtitle">Clientes convertidos desde Leads</p>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-12">
            <div class="card" style="background-color: #1e1e1e; border: 1px solid #333333;">
                <div class="card-header" style="background-color: #2a2a2a; color: #ffffff; border-bottom: 1px solid #333333;">
                    <h5 class="mb-0 filter-title"><i class="fas fa-filter"></i> Filtros de Búsqueda</h5>
                </div>
                <div class="card-body" style="background-color: #1e1e1e;">
                    <div class="row">
                        <div class="col-md-3 mb-2">
                            <input type="text" class="form-control" id="filtroID" placeholder="Buscar por ID">
                        </div>
                        <div class="col-md-3 mb-2">
                            <input type="text" class="form-control" id="filtroNombre" placeholder="Buscar por Nombre">
                        </div>
                        <div class="col-md-2 mb-2">
                            <input type="text" class="form-control" id="filtroTelefono" placeholder="Teléfono">
                        </div>
                        <div class="col-md-2 mb-2">
                            <input type="text" class="form-control" id="filtroCorreo" placeholder="Correo">
                        </div>
                        <div class="col-md-2 mb-2">
                            <button type="button" class="btn btn-success w-100" id="btnBuscar">
                                <i class="fas fa-search"></i> Buscar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card match-table-card" style="background-color: #1e1e1e; border: 1px solid #333333;">
                <div class="card-body" style="background-color: #1e1e1e;">
                    <div class="table-responsive">
                        <table id="tablaClientesMatch" class="table table-dark table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Tipo Match</th>
                                    <th>Nombre</th>
                                    <th>RUT</th>
                                    <th>Teléfono</th>
                                    <th>Correo</th>
                                    <th>Comuna</th>
                                    <th>Profesión</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="ModificarModal" />

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/clientesmatch.js" asp-append-version="true"></script>
}
