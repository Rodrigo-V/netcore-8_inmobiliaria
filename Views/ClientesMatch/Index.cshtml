@{
    ViewData["Title"] = "Clientes Match";
}

<!-- Estilos externos -->
<link rel="stylesheet" href="~/css/clientesmatch.css" />
<!-- SweetAlert2 CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

<div class="container-fluid" style="background-color: #121212; min-height: 100vh; padding: 20px;">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-0" style="color: #ffffff;">
                <i class="fas fa-handshake"></i> Clientes Match
            </h2>
            <p style="color: #b0b0b0;">Clientes convertidos desde Leads</p>
        </div>
    </div>

    <!-- Filtros de búsqueda -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="card" style="background-color: #1e1e1e; border: 1px solid #333333;">
                <div class="card-header" style="background-color: #2a2a2a; color: #ffffff; border-bottom: 1px solid #333333;">
                    <h5 class="mb-0">
                        <i class="fas fa-filter"></i> Filtros de Búsqueda
                    </h5>
                </div>
                <div class="card-body" style="background-color: #1e1e1e;">
                    <div class="row">
                        <div class="col-md-3 mb-2">
                            <input type="text" class="form-control" id="filtroID" placeholder="Buscar por ID" style="background-color: #2a2a2a; border-color: #444444; color: #ffffff;">
                        </div>
                        <div class="col-md-3 mb-2">
                            <input type="text" class="form-control" id="filtroNombre" placeholder="Buscar por Nombre" style="background-color: #2a2a2a; border-color: #444444; color: #ffffff;">
                        </div>
                        <div class="col-md-2 mb-2">
                            <input type="text" class="form-control" id="filtroTelefono" placeholder="Teléfono" style="background-color: #2a2a2a; border-color: #444444; color: #ffffff;">
                        </div>
                        <div class="col-md-2 mb-2">
                            <input type="text" class="form-control" id="filtroCorreo" placeholder="Correo" style="background-color: #2a2a2a; border-color: #444444; color: #ffffff;">
                        </div>
                        <div class="col-md-2 mb-2">
                            <button type="button" class="btn btn-success w-100" id="btnBuscar">
                                <i class="fas fa-search"></i> Buscar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Clientes Match -->
    <div class="row">
        <div class="col-12">
            <div class="card" style="background-color: #1e1e1e; border: 1px solid #333333;">
                <div class="card-body" style="background-color: #1e1e1e;">
                    <div class="table-responsive">
                        <table id="tablaClientesMatch" class="table table-dark table-striped table-hover" style="color: #ffffff;">
                            <thead style="background-color: #2a2a2a;">
                                <tr>
                                    <th>ID</th>
                                    <th>Tipo Match</th>
                                    <th>Nombre</th>
                                    <th>RUT</th>
                                    <th>Teléfono</th>
                                    <th>Correo</th>
                                    <th>Comuna</th>
                                    <th>Profesión</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Los datos se cargan dinámicamente -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Modificar -->
<partial name="ModificarModal" />

<!-- SweetAlert2 JS -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- JavaScript externo -->
<script src="~/js/clientesmatch.js"></script>

<script>
    // Inicializar al cargar la página
    $(document).ready(function() {
        console.log('🚀 Inicializando Clientes Match...');
        
        // Verificar que las funciones existan
        if (typeof inicializarDataTablesMatch === 'function') {
            inicializarDataTablesMatch();
        } else {
            console.error('❌ La función inicializarDataTablesMatch no está definida');
        }
        
        if (typeof cargarClientesMatch === 'function') {
            cargarClientesMatch();
        } else {
            console.error('❌ La función cargarClientesMatch no está definida');
        }
        
        // Evento del botón buscar
        $('#btnBuscar').on('click', function() {
            cargarClientesMatch();
        });
        
        // Buscar con Enter en los filtros
        $('#filtroID, #filtroNombre, #filtroTelefono, #filtroCorreo').on('keypress', function(e) {
            if (e.which === 13) {
                cargarClientesMatch();
            }
        });
    });
</script>

