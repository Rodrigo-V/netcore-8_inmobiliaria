@{
    ViewData["Title"] = "Seguimiento Activo";
}

<link rel="stylesheet" href="~/css/seguimientoactivo.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

<div class="container-fluid" style="background-color: #121212; min-height: 100vh; padding: 20px;">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-0" style="color: #ffffff;">
                <i class="fas fa-tasks"></i> Seguimiento Activo
            </h2>
            <p style="color: #b0b0b0;">Gestión de seguimientos de clientes leads</p>
        </div>
    </div>

    <!-- Filtros -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="card" style="background-color: #1e1e1e; border: 1px solid #333333;">
                <div class="card-header" style="background-color: #2a2a2a; color: #ffffff; border-bottom: 1px solid #333333;">
                    <h5 class="mb-0"><i class="fas fa-filter"></i> Filtros</h5>
                </div>
                <div class="card-body" style="background-color: #1e1e1e;">
                    <div class="row">
                        <div class="col-md-3 mb-2">
                            <input type="text" class="form-control" id="filtroCliente" placeholder="ID Cliente" style="background-color: #2a2a2a; border-color: #444444; color: #ffffff;">
                        </div>
                        <div class="col-md-3 mb-2">
                            <input type="text" class="form-control" id="filtroAgente" placeholder="Agente" style="background-color: #2a2a2a; border-color: #444444; color: #ffffff;">
                        </div>
                        <div class="col-md-2 mb-2">
                            <select class="form-select" id="filtroTipoAccion" style="background-color: #2a2a2a; border-color: #444444; color: #ffffff;">
                                <option value="">Tipo Acción</option>
                                <option value="Llamada">Llamada</option>
                                <option value="WhatsApp">WhatsApp</option>
                                <option value="Email">Email</option>
                                <option value="Visita">Visita</option>
                            </select>
                        </div>
                        <div class="col-md-2 mb-2">
                            <select class="form-select" id="filtroEstado" style="background-color: #2a2a2a; border-color: #444444; color: #ffffff;">
                                <option value="">Estado</option>
                                <option value="Pendiente">Pendiente</option>
                                <option value="Completado">Completado</option>
                            </select>
                        </div>
                        <div class="col-md-2 mb-2">
                            <button type="button" class="btn btn-success w-100" id="btnBuscar">
                                <i class="fas fa-search"></i> Buscar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    <div class="row">
        <div class="col-12">
            <div class="card" style="background-color: #1e1e1e; border: 1px solid #333333;">
                <div class="card-body" style="background-color: #1e1e1e;">
                    <div class="table-responsive">
                        <table id="tablaSeguimiento" class="table table-dark table-striped table-hover" style="color: #ffffff;">
                            <thead style="background-color: #2a2a2a;">
                                <tr>
                                    <th>Cliente</th>
                                    <th>Agente</th>
                                    <th>Fecha</th>
                                    <th>Tipo</th>
                                    <th>Descripción</th>
                                    <th>Resultado</th>
                                    <th>Estado</th>
                                    <th>Próximo Contacto</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/js/seguimientoactivo.js"></script>

<script>
    $(document).ready(function() {
        console.log('🚀 Inicializando Seguimiento Activo...');
        if (typeof inicializarDataTablesSeguimiento === 'function') {
            inicializarDataTablesSeguimiento();
        }
        if (typeof cargarSeguimientos === 'function') {
            cargarSeguimientos();
        }
        $('#btnBuscar').on('click', function() {
            cargarSeguimientos();
        });
    });
</script>

