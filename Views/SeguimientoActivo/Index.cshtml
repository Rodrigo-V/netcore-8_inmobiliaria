@{
    ViewData["Title"] = "Seguimiento Activo";
}

<link rel="stylesheet" href="~/css/seguimientoactivo.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

<div class="container-fluid seguimiento-module" style="background-color: #121212; min-height: 100vh; padding: 16px;">
    <div class="row mb-3">
        <div class="col-12">
            <h2 class="module-title mb-0"><i class="fas fa-tasks"></i> Seguimiento Activo</h2>
            <p class="module-subtitle">Gestión de seguimientos de clientes leads</p>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-12">
            <div class="card" style="background-color: #1e1e1e; border: 1px solid #333333;">
                <div class="card-header" style="background-color: #2a2a2a; color: #ffffff; border-bottom: 1px solid #333333;">
                    <h5 class="mb-0 filter-title"><i class="fas fa-filter"></i> Filtros</h5>
                </div>
                <div class="card-body" style="background-color: #1e1e1e;">
                    <div class="row">
                        <div class="col-md-3 mb-2">
                            <select class="form-select" id="filtroCliente">
                                <option value="">Todos los clientes</option>
                            </select>
                        </div>
                        <div class="col-md-3 mb-2">
                            <select class="form-select" id="filtroAgente">
                                <option value="">Todos los agentes</option>
                            </select>
                        </div>
                        <div class="col-md-2 mb-2">
                            <select class="form-select" id="filtroTipoAccion">
                                <option value="">Tipo Acción</option>
                                <option value="Llamada">Llamada</option>
                                <option value="WhatsApp">WhatsApp</option>
                                <option value="Email">Email</option>
                                <option value="Visita">Visita</option>
                            </select>
                        </div>
                        <div class="col-md-2 mb-2">
                            <select class="form-select" id="filtroEstado">
                                <option value="">Estado</option>
                                <option value="Pendiente">Pendiente</option>
                                <option value="Completado">Completado</option>
                            </select>
                        </div>
                        <div class="col-md-2 mb-2">
                            <button type="button" class="btn btn-success w-100" id="btnBuscar">
                                <i class="fas fa-search"></i> Buscar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card seguimiento-table-card" style="background-color: #1e1e1e; border: 1px solid #333333;">
                <div class="card-body" style="background-color: #1e1e1e;">
                    <div class="table-responsive">
                        <table id="tablaSeguimiento" class="display" cellpadding="0" cellspacing="0" border="0" width="100%">
                            <thead>
                                <tr>
                                    <th>Cliente</th>
                                    <th>Agente</th>
                                    <th>Fecha</th>
                                    <th>Tipo</th>
                                    <th>Descripción</th>
                                    <th>Resultado</th>
                                    <th>Estado</th>
                                    <th>Próximo Contacto</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/seguimientoactivo.js" asp-append-version="true"></script>
}
