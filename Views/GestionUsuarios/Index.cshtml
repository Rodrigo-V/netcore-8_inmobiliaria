@model List<Inmobiliaria.Net8.DTOs.Usuario>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<link rel="stylesheet" href="~/css/gestionusuarios.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

<div class="container-fluid">
    <!-- Header -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="mb-0">
                                <i class="fas fa-users-cog"></i>
                                Gestión de Usuarios
                            </h4>
                            <small>Administración completa del sistema de usuarios</small>
                        </div>
                        <a href="@Url.Action("Crear")" class="btn btn-light">
                            <i class="fas fa-plus"></i>
                            Nuevo Usuario
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Mensajes -->
    @if (TempData["Success"] != null)
    {
        <div class="row mt-3">
            <div class="col-12">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle"></i>
                    <strong>Éxito:</strong> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="row mt-3">
            <div class="col-12">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle"></i>
                    <strong>Error:</strong> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    <!-- Estadísticas -->
    <div class="row mt-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-chart-bar"></i>
                        Estadísticas del Sistema
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-2">
                            <div class="card bg-primary text-white">
                                <div class="card-body">
                                    <h3 class="card-title">@(ViewBag.Estadisticas?.TotalUsuarios ?? 0)</h3>
                                    <p class="card-text">Total Usuarios</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card bg-success text-white">
                                <div class="card-body">
                                    <h3 class="card-title">@(ViewBag.Estadisticas?.UsuariosActivos ?? 0)</h3>
                                    <p class="card-text">Usuarios Activos</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card bg-warning text-white">
                                <div class="card-body">
                                    <h3 class="card-title">@(ViewBag.Estadisticas?.UsuariosInactivos ?? 0)</h3>
                                    <p class="card-text">Usuarios Inactivos</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card bg-info text-white">
                                <div class="card-body">
                                    <h3 class="card-title">@(ViewBag.Estadisticas?.TotalRoles ?? 0)</h3>
                                    <p class="card-text">Roles Diferentes</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card bg-secondary text-white">
                                <div class="card-body">
                                    <h3 class="card-title">@(ViewBag.Estadisticas?.UsuariosActivosUltimaSemana ?? 0)</h3>
                                    <p class="card-text">Activos Esta Semana</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card bg-dark text-white">
                                <div class="card-body">
                                    <h3 class="card-title">@(ViewBag.Estadisticas?.UsuariosActivosUltimoMes ?? 0)</h3>
                                    <p class="card-text">Activos Este Mes</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Usuarios -->
    <div class="row mt-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-list"></i>
                        Lista de Usuarios (@Model.Count usuarios)
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover" id="tablaUsuarios">
                                <thead>
                                    <tr>
                                        <th>Usuario</th>
                                        <th>Correo</th>
                                        <th>Rol</th>
                                        <th>Estado</th>
                                        <th>Último Acceso</th>
                                        <th>Fecha Creación</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var usuario in Model)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar-sm me-3">
                                                        <div class="avatar-initials">
                                                            @usuario.InicialAvatar
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <strong>@usuario.NombreCompleto</strong>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>@usuario.Correo_Electronico</td>
                                            <td>
                                                @{
                                                    string badgeClass = usuario.Rol switch
                                                    {
                                                        "Admin TI" => "badge bg-danger",
                                                        "Administrador" => "badge bg-warning",
                                                        "Agente" => "badge bg-info",
                                                        _ => "badge bg-secondary"
                                                    };
                                                }
                                                <span class="@badgeClass">
                                                    @usuario.Rol
                                                </span>
                                            </td>
                                            <td>
                                                @if (usuario.Activo)
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-check-circle"></i> Activo
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">
                                                        <i class="fas fa-times-circle"></i> Inactivo
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                @if (usuario.Ultimo_Acceso.HasValue)
                                                {
                                                    <small>@usuario.Ultimo_Acceso.Value.ToString("dd/MM/yyyy HH:mm")</small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Nunca</span>
                                                }
                                            </td>
                                            <td>
                                                <small>@usuario.Fecha_Creacion.ToString("dd/MM/yyyy")</small>
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a href="@Url.Action("Editar", new { id = usuario.ID_Usuario })" 
                                                       class="btn btn-sm btn-outline-primary" 
                                                       title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    @if (usuario.Activo)
                                                    {
                                                        <button type="button" 
                                                                class="btn btn-sm btn-outline-warning" 
                                                                onclick="cambiarEstado(@usuario.ID_Usuario, false)"
                                                                title="Desactivar">
                                                            <i class="fas fa-user-slash"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" 
                                                                class="btn btn-sm btn-outline-success" 
                                                                onclick="cambiarEstado(@usuario.ID_Usuario, true)"
                                                                title="Activar">
                                                            <i class="fas fa-user-check"></i>
                                                        </button>
                                                    }
                                                    <button type="button" 
                                                            class="btn btn-sm btn-outline-danger" 
                                                            onclick="eliminarUsuario(@usuario.ID_Usuario)"
                                                            title="Eliminar">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-users fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No hay usuarios registrados</h5>
                            <p class="text-muted">Comienza creando el primer usuario del sistema.</p>
                            <a href="@Url.Action("Crear")" class="btn btn-primary">
                                <i class="fas fa-plus"></i>
                                Crear Usuario
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/gestionusuarios.js" asp-append-version="true"></script>
}

