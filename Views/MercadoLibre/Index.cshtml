@model Inmobiliaria.Net8.DTOs.EstadoConexionML

@{
    ViewData["Title"] = "Configuración Mercado Libre";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>
                    <i class="bi bi-cart-check text-warning"></i>
                    Configuración de Mercado Libre
                </h2>
                <a href="@Url.Action("Index", "Propiedades")" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Volver a Propiedades
                </a>
            </div>

            @* Mensajes de feedback *@
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @ViewBag.Error
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @* Card de Estado de Conexión *@
            <div class="row mb-4">
                <div class="col-md-8 mx-auto">
                    <div class="card shadow">
                        <div class="card-header bg-warning text-dark">
                            <h5 class="mb-0">
                                <i class="bi bi-globe"></i>
                                Estado de la Conexión
                            </h5>
                        </div>
                        <div class="card-body">
                            @if (Model.Conectado)
                            {
                                <div class="text-center">
                                    <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                                    <h4 class="text-success mt-3">¡Conectado a Mercado Libre!</h4>
                                    
                                    <div class="mt-4">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="card bg-light">
                                                    <div class="card-body">
                                                        <h6 class="text-muted">User ID</h6>
                                                        <h5>@Model.UserId</h5>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="card bg-light">
                                                    <div class="card-body">
                                                        <h6 class="text-muted">Expira en</h6>
                                                        <h5>
                                                            @if (Model.DiasRestantes > 30)
                                                            {
                                                                <span class="text-success">@Model.DiasRestantes días</span>
                                                            }
                                                            else if (Model.DiasRestantes > 0)
                                                            {
                                                                <span class="text-warning">@Model.DiasRestantes días</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-danger">Expirado</span>
                                                            }
                                                        </h5>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        @if (Model.FechaExpiracion.HasValue)
                                        {
                                            <p class="text-muted mt-3 mb-1">
                                                <small>Fecha de expiración: @Model.FechaExpiracion.Value.ToString("dd/MM/yyyy HH:mm")</small>
                                            </p>
                                        }
                                        
                                        <p class="mt-2">
                                            <i class="bi bi-info-circle text-info"></i>
                                            @Model.Mensaje
                                        </p>
                                    </div>

                                    <div class="mt-4">
                                        <form asp-action="RenovarToken" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-outline-warning">
                                                <i class="bi bi-arrow-repeat"></i>
                                                Renovar Token
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="text-center">
                                    <i class="bi bi-x-circle-fill text-danger" style="font-size: 4rem;"></i>
                                    <h4 class="text-danger mt-3">No Conectado</h4>
                                    <p class="text-muted mt-3">@Model.Mensaje</p>
                                    
                                    <div class="mt-4">
                                        <a href="@Url.Action("Autorizar")" class="btn btn-warning btn-lg">
                                            <i class="bi bi-box-arrow-in-right"></i>
                                            Conectar con Mercado Libre
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* Información de ayuda *@
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="bi bi-info-circle"></i>
                                ¿Cómo funciona?
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="text-center mb-3">
                                        <i class="bi bi-1-circle-fill text-primary" style="font-size: 2.5rem;"></i>
                                        <h6 class="mt-2">Conectar</h6>
                                        <p class="text-muted small">
                                            Haz clic en "Conectar con Mercado Libre" para autorizar la aplicación
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="text-center mb-3">
                                        <i class="bi bi-2-circle-fill text-primary" style="font-size: 2.5rem;"></i>
                                        <h6 class="mt-2">Autorizar</h6>
                                        <p class="text-muted small">
                                            Inicia sesión en Mercado Libre y autoriza el acceso a tus publicaciones
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="text-center mb-3">
                                        <i class="bi bi-3-circle-fill text-primary" style="font-size: 2.5rem;"></i>
                                        <h6 class="mt-2">Ver Estadísticas</h6>
                                        <p class="text-muted small">
                                            Podrás ver las visitas de tus publicaciones desde el módulo de propiedades
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <hr class="my-4">

                            <h6><i class="bi bi-shield-check text-success"></i> Seguridad</h6>
                            <ul class="text-muted small">
                                <li>Los tokens se almacenan de forma segura en la base de datos</li>
                                <li>El access token se renueva automáticamente cuando es necesario</li>
                                <li>Solo el administrador del sistema puede establecer la conexión</li>
                                <li>Los tokens expiran después de 6 meses de inactividad</li>
                            </ul>

                            <h6 class="mt-3"><i class="bi bi-graph-up text-info"></i> Funcionalidades</h6>
                            <ul class="text-muted small">
                                <li>Ver visitas totales históricas de cada publicación</li>
                                <li>Ver visitas de los últimos 7, 30 o 150 días</li>
                                <li>Gráficos de visitas por día</li>
                                <li>Estadísticas consolidadas de todas tus publicaciones</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-cerrar alertas después de 5 segundos
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}

