@model Inmobiliaria.Net8.DTOs.EstadisticasVisitasML

@{
    ViewData["Title"] = "Visitas - " + Model.TituloPropiedad;
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>
                    <i class="bi bi-eye text-primary"></i>
                    Estadísticas de Visitas
                </h2>
                <button onclick="window.history.back()" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Volver
                </button>
            </div>

            @* Mensajes de error *@
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @* Información de la publicación *@
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">@Model.TituloPropiedad</h5>
                    <p class="text-muted mb-0">
                        <small>
                            <strong>ID Mercado Libre:</strong> @Model.ItemId
                            <span class="ms-3">
                                <strong>Fecha de consulta:</strong> @Model.FechaConsulta.ToString("dd/MM/yyyy HH:mm")
                            </span>
                        </small>
                    </p>
                </div>
            </div>

            @* Tarjetas de estadísticas principales *@
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card text-center shadow-sm">
                        <div class="card-body">
                            <i class="bi bi-eye-fill text-primary" style="font-size: 2.5rem;"></i>
                            <h3 class="mt-3 mb-0">@Model.VisitasTotales.ToString("N0")</h3>
                            <p class="text-muted mb-0">Visitas Totales</p>
                            <small class="text-muted">(Histórico)</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center shadow-sm">
                        <div class="card-body">
                            <i class="bi bi-calendar-month text-success" style="font-size: 2.5rem;"></i>
                            <h3 class="mt-3 mb-0">@Model.VisitasUltimos30Dias.ToString("N0")</h3>
                            <p class="text-muted mb-0">Últimos 30 Días</p>
                            <small class="text-muted">
                                Promedio: @((Model.VisitasUltimos30Dias / 30.0).ToString("N1")) visitas/día
                            </small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center shadow-sm">
                        <div class="card-body">
                            <i class="bi bi-calendar-week text-warning" style="font-size: 2.5rem;"></i>
                            <h3 class="mt-3 mb-0">@Model.VisitasUltimos7Dias.ToString("N0")</h3>
                            <p class="text-muted mb-0">Últimos 7 Días</p>
                            <small class="text-muted">
                                Promedio: @((Model.VisitasUltimos7Dias / 7.0).ToString("N1")) visitas/día
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            @* Gráfico de visitas por día *@
            @if (Model.VisitasPorDia != null && Model.VisitasPorDia.Any())
            {
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="bi bi-graph-up"></i>
                            Visitas por Día (Últimos 30 días)
                        </h5>
                    </div>
                    <div class="card-body">
                        <canvas id="chartVisitasPorDia" style="max-height: 400px;"></canvas>
                    </div>
                </div>

                @* Tabla de datos detallados *@
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="bi bi-table"></i>
                            Detalle de Visitas por Día
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover table-striped" id="tablaVisitas">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Día</th>
                                        <th class="text-end">Visitas</th>
                                        <th class="text-center">Gráfico</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var maxVisitas = Model.VisitasPorDia.Max(v => v.Visitas);
                                    }
                                    @foreach (var visita in Model.VisitasPorDia.OrderByDescending(v => v.Fecha))
                                    {
                                        var porcentaje = maxVisitas > 0 ? (visita.Visitas * 100.0 / maxVisitas) : 0;
                                        <tr>
                                            <td>@visita.Fecha.ToString("dd/MM/yyyy")</td>
                                            <td>@visita.Fecha.ToString("dddd", new System.Globalization.CultureInfo("es-ES"))</td>
                                            <td class="text-end">
                                                <strong>@visita.Visitas.ToString("N0")</strong>
                                            </td>
                                            <td>
                                                <div class="progress" style="height: 20px;">
                                                    <div class="progress-bar bg-primary" role="progressbar" 
                                                         style="width: @porcentaje.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"
                                                         aria-valuenow="@visita.Visitas" aria-valuemin="0" aria-valuemax="@maxVisitas">
                                                        @if (visita.Visitas > 0)
                                                        {
                                                            @visita.Visitas
                                                        }
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <td colspan="2"><strong>TOTAL</strong></td>
                                        <td class="text-end">
                                            <strong>@Model.VisitasPorDia.Sum(v => v.Visitas).ToString("N0")</strong>
                                        </td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    No hay datos de visitas detalladas disponibles para esta publicación.
                </div>
            }

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        @if (Model.VisitasPorDia != null && Model.VisitasPorDia.Any())
        {
            <text>
            // Preparar datos para el gráfico
            const fechas = @Html.Raw(Json.Serialize(Model.VisitasPorDia.Select(v => v.Fecha.ToString("dd/MM"))));
            const visitas = @Html.Raw(Json.Serialize(Model.VisitasPorDia.Select(v => v.Visitas)));

            // Crear gráfico
            const ctx = document.getElementById('chartVisitasPorDia').getContext('2d');
            const chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: fechas,
                    datasets: [{
                        label: 'Visitas',
                        data: visitas,
                        borderColor: 'rgb(13, 110, 253)',
                        backgroundColor: 'rgba(13, 110, 253, 0.1)',
                        borderWidth: 2,
                        tension: 0.3,
                        fill: true,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        pointBackgroundColor: 'rgb(13, 110, 253)',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            display: false
                        },
                        title: {
                            display: false
                        },
                        tooltip: {
                            backgroundColor: 'rgba(0, 0, 0, 0.8)',
                            padding: 12,
                            titleFont: {
                                size: 14
                            },
                            bodyFont: {
                                size: 13
                            },
                            callbacks: {
                                label: function(context) {
                                    return 'Visitas: ' + context.parsed.y.toLocaleString('es-CL');
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return value.toLocaleString('es-CL');
                                }
                            },
                            grid: {
                                color: 'rgba(0, 0, 0, 0.05)'
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    },
                    interaction: {
                        mode: 'index',
                        intersect: false
                    }
                }
            });
            </text>
        }

        // DataTable para la tabla
        $(document).ready(function() {
            $('#tablaVisitas').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json'
                },
                order: [[0, 'desc']],
                pageLength: 15,
                dom: 'Bfrtip',
                buttons: [
                    {
                        extend: 'excel',
                        text: '<i class="bi bi-file-earmark-excel"></i> Excel',
                        className: 'btn btn-success btn-sm'
                    },
                    {
                        extend: 'pdf',
                        text: '<i class="bi bi-file-earmark-pdf"></i> PDF',
                        className: 'btn btn-danger btn-sm'
                    },
                    {
                        extend: 'print',
                        text: '<i class="bi bi-printer"></i> Imprimir',
                        className: 'btn btn-info btn-sm'
                    }
                ]
            });
        });
    </script>
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap5.min.css">
}

