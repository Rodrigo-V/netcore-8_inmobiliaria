@{
    ViewData["Title"] = "Configuración de Imágenes";
}

<link rel="stylesheet" href="~/css/configuracionimagenes.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

<div class="configuracion-imagenes">
    <div class="header-section">
        <h2><i class="fas fa-images"></i> Configuración de Imágenes</h2>
        <p>Gestiona las imágenes de las propiedades desde Google Drive</p>
    </div>

    <div class="stats-cards">
        <div class="stat-card">
            <div class="stat-number">@(ViewBag.Estadisticas?.TotalPropiedades ?? 0)</div>
            <div class="stat-label">Total Propiedades</div>
        </div>
        <div class="stat-card success">
            <div class="stat-number">@(ViewBag.Estadisticas?.ConImagen ?? 0)</div>
            <div class="stat-label">Con Imagen</div>
        </div>
        <div class="stat-card warning">
            <div class="stat-number">@(ViewBag.Estadisticas?.SinImagen ?? 0)</div>
            <div class="stat-label">Sin Imagen</div>
        </div>
        <div class="stat-card info">
            <div class="stat-number">@(ViewBag.Estadisticas?.PorcentajeCobertura ?? 0)%</div>
            <div class="stat-label">Cobertura</div>
        </div>
    </div>

    <div class="search-section">
        <h4><i class="fas fa-search"></i> Buscar Propiedad</h4>
        <input type="text" id="buscarPropiedad" class="form-control" placeholder="Buscar por ID, título, dirección o comuna...">
    </div>

    <div class="properties-grid" id="gridPropiedades"></div>

    <div class="pagination-bar" id="paginacionImagenes">
        <button type="button" class="btn btn-sm btn-outline-light" id="btnPaginaAnterior" disabled>
            <i class="fas fa-chevron-left"></i> Anterior
        </button>
        <span id="infoPaginacion" class="pagination-info">Cargando...</span>
        <button type="button" class="btn btn-sm btn-outline-light" id="btnPaginaSiguiente" disabled>
            Siguiente <i class="fas fa-chevron-right"></i>
        </button>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/configuracionimagenes.js" asp-append-version="true"></script>
}
