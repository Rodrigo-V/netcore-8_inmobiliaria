@{
    ViewData["Title"] = "Configuración de Imágenes";
}

<link rel="stylesheet" href="~/css/configuracionimagenes.css" />
<!-- SweetAlert2 CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

<div class="configuracion-imagenes">
    <!-- Header -->
    <div class="header-section">
        <h2><i class="fas fa-images"></i> Configuración de Imágenes</h2>
        <p>Gestiona las imágenes de las propiedades desde Google Drive</p>
    </div>

    <!-- Estadísticas -->
    <div class="stats-cards">
        <div class="stat-card">
            <div class="stat-number">@(ViewBag.Estadisticas?.TotalPropiedades ?? 0)</div>
            <div class="stat-label">Total Propiedades</div>
        </div>
        <div class="stat-card success">
            <div class="stat-number">@(ViewBag.Estadisticas?.ConImagen ?? 0)</div>
            <div class="stat-label">Con Imagen</div>
        </div>
        <div class="stat-card warning">
            <div class="stat-number">@(ViewBag.Estadisticas?.SinImagen ?? 0)</div>
            <div class="stat-label">Sin Imagen</div>
        </div>
        <div class="stat-card info">
            <div class="stat-number">@(ViewBag.Estadisticas?.PorcentajeCobertura ?? 0)%</div>
            <div class="stat-label">Cobertura</div>
        </div>
    </div>

    <!-- Búsqueda -->
    <div class="search-section">
        <h4><i class="fas fa-search"></i> Buscar Propiedad</h4>
        <input type="text" id="buscarPropiedad" class="form-control" placeholder="Buscar por ID, título, dirección o comuna...">
    </div>

    <!-- Grid de Propiedades -->
    <div class="properties-grid" id="gridPropiedades">
        @if (ViewBag.Propiedades != null)
        {
            @foreach (var propiedad in ViewBag.Propiedades)
            {
                <div class="property-card" data-id="@propiedad.ID_Propiedad">
                    <div class="property-image">
                        @if (!string.IsNullOrEmpty(propiedad.Url_Imagen))
                        {
                            <img src="@propiedad.Url_Imagen" alt="@propiedad.Title" style="width: 100%; height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <i class="fas fa-image"></i>
                        }
                    </div>
                    <div class="property-info">
                        <div class="property-id">@propiedad.ID_Propiedad</div>
                        <div class="property-title">@propiedad.Title</div>
                        <div class="property-details">
                            <small><i class="fas fa-map-marker-alt"></i> @propiedad.Comuna</small>
                        </div>
                        <div class="property-actions">
                            <button onclick="editarUrl('@propiedad.ID_Propiedad')" class="btn btn-sm btn-primary">
                                <i class="fas fa-edit"></i> URL
                            </button>
                            @if (!string.IsNullOrEmpty(propiedad.Url_Imagen))
                            {
                                <button onclick="eliminarImagen('@propiedad.ID_Propiedad')" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- SweetAlert2 JS -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/js/configuracionimagenes.js"></script>

