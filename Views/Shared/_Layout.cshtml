@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@inject IHttpContextAccessor HttpContextAccessor

@{
    var usuarioNombre = User.FindFirst("NombreCompleto")?.Value ?? "Usuario";
    var usuarioRol = User.FindFirst(ClaimTypes.Role)?.Value ?? "Sin rol";
    var usuarioIniciales = User.FindFirst("Iniciales")?.Value ?? "US";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower() ?? "";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Inmobiliario</title>
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" asp-append-version="true" />
    
    <!-- FontAwesome -->
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" asp-append-version="true" />
    
    <!-- DataTables CSS (opcional, solo si se usa en la vista) -->
    <link rel="stylesheet" href="~/lib/datatables-dt/css/jquery.dataTables.min.css" asp-append-version="true" />
    
    <!-- Sidebar CSS -->
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    
    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <!-- jQuery (cargado primero) -->
    <script src="~/lib/jquery/jquery.min.js" asp-append-version="true"></script>
</head>

<body class="sidebar-layout">
    <script>
        window.SiteRoot = "@Url.Content("~/")";
        window.CurrentController = "@currentController";
    </script>

    <!-- Botón de menú móvil -->
    <button class="menu-toggle">
        <i class="fas fa-bars"></i>
    </button>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="user-avatar" id="sidebarAvatar">@usuarioIniciales</div>
            <div class="user-details">
                <h4 id="sidebarUserName">@usuarioNombre</h4>
                <p id="sidebarUserRole">@usuarioRol</p>
            </div>
        </div>

        <nav class="sidebar-nav">
            <!-- Sección General -->
            <div class="nav-section">
                <div class="nav-section-title">GENERAL</div>
                <a href="@Url.Action("Index", "ClientesLeads")" class="nav-item" data-controller="clientesleads">
                    <i class="fas fa-home"></i>
                    Inicio - Clientes Leads
                </a>
                <a href="@Url.Action("Index", "ClientesMatch")" class="nav-item" data-controller="clientesmatch">
                    <i class="fas fa-handshake"></i>
                    Clientes Match
                </a>
                <a href="@Url.Action("Index", "ClientesMatriz")" class="nav-item" data-controller="clientesmatriz">
                    <i class="fas fa-users"></i>
                    Clientes Matriz
                </a>
                <a href="@Url.Action("Index", "Propiedades")" class="nav-item" data-controller="propiedades">
                    <i class="fas fa-building"></i>
                    Propiedades
                </a>
                <a href="@Url.Action("Index", "SeguimientoActivo")" class="nav-item" data-controller="seguimientoactivo">
                    <i class="fas fa-tasks"></i>
                    Seguimiento Activo
                </a>
            </div>

            <!-- Sección Administración (solo para administradores) -->
            @if (usuarioRol == "Administrador")
            {
                <div class="nav-section">
                    <div class="nav-section-title">ADMINISTRACIÓN</div>
                    <a href="@Url.Action("Index", "GestionUsuarios")" class="nav-item" data-controller="gestionusuarios">
                        <i class="fas fa-users-cog"></i>
                        Gestión de Usuarios
                    </a>
                    <a href="@Url.Action("VistaMatriz", "SincronizacionPortales")" class="nav-item" data-controller="sincronizacionportales">
                        <i class="fas fa-sync-alt"></i>
                        Sincronización Portales
                    </a>
                    <a href="@Url.Action("Index", "SincronizacionPortales2")" class="nav-item" data-controller="sincronizacionportales2">
                        <i class="fas fa-th-large"></i>
                        Sincronización Portales 2
                    </a>
                    <a href="@Url.Action("Index", "ConfiguracionImagenes")" class="nav-item" data-controller="configuracionimagenes">
                        <i class="fas fa-images"></i>
                        Config. Imágenes
                    </a>
                    <a href="@Url.Action("Index", "APITest")" class="nav-item" data-controller="apitest">
                        <i class="fas fa-plug"></i>
                        Pruebas APIs
                    </a>
                    <a href="@Url.Action("Index", "ConfiguracionPortales")" class="nav-item" data-controller="configuracionportales">
                        <i class="fas fa-link"></i>
                        Config. IDs Portales
                    </a>
                    <a href="@Url.Action("Index", "CargadorExcelPropit")" class="nav-item" data-controller="cargadorexcelpropit">
                        <i class="fas fa-file-excel"></i>
                        Cargador Excel Propit
                    </a>
                </div>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="footer-links">
                <a href="#">Políticas de privacidad</a>
                <a href="#">Términos y condiciones</a>
            </div>
            <div class="copyright">
                © 2025 Rosch
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Top Bar -->
        <div class="top-bar">
            <div class="page-title">
                <h2>Sistema de Gestión Inmobiliaria</h2>
            </div>
            
            <!-- Información del usuario y menú -->
            <div class="user-info">
                <div class="user-menu">
                    <div class="user-avatar-small">@usuarioIniciales</div>
                    <div class="user-dropdown" id="userDropdown">
                        <a href="@Url.Action("Index", "MiPerfil")" class="dropdown-item">
                            <i class="fas fa-user"></i>
                            Mi Perfil
                        </a>
                        <a href="@Url.Action("Index", "Configuracion")" class="dropdown-item">
                            <i class="fas fa-cog"></i>
                            Configuración
                        </a>
                        <a href="#" class="dropdown-item logout-btn" id="btnLogout">
                            <i class="fas fa-sign-out-alt"></i>
                            Cerrar Sesión
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Área de contenido -->
        <div class="content-area">
            @RenderBody()
        </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    
    <!-- DataTables JS (opcional, solo si se usa) -->
    <script src="~/lib/datatables/jquery.dataTables.min.js" asp-append-version="true"></script>
    
    <!-- Site JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Scripts del Sidebar -->
    <script>
        $(document).ready(function () {
            // Marcar el elemento activo del menú
            var currentController = '@currentController';
            
            $('.nav-item').each(function() {
                var itemController = $(this).data('controller');
                if (itemController && itemController.toLowerCase() === currentController.toLowerCase()) {
                    $(this).addClass('active');
                }
            });

            // Funcionalidad del menú móvil
            $('.menu-toggle').click(function() {
                $('.sidebar').toggleClass('active');
            });

            // Cerrar sidebar en móvil al hacer clic en un enlace
            $('.nav-item').click(function() {
                if (window.innerWidth <= 768) {
                    $('.sidebar').removeClass('active');
                }
            });

            // Cerrar sidebar al hacer clic fuera de él en móvil
            $(document).click(function(e) {
                if (window.innerWidth <= 768) {
                    if (!$(e.target).closest('.sidebar, .menu-toggle').length) {
                        $('.sidebar').removeClass('active');
                    }
                }
            });

            // Menú desplegable del usuario
            $('.user-menu').click(function(e) {
                e.stopPropagation();
                $('#userDropdown').toggleClass('show');
            });

            // Cerrar menú al hacer clic fuera
            $(document).click(function(e) {
                if (!$(e.target).closest('.user-menu').length) {
                    $('#userDropdown').removeClass('show');
                }
            });

            // Logout
            $('#btnLogout').click(function(e) {
                e.preventDefault();
                
                if (confirm('¿Está seguro que desea cerrar sesión?')) {
                    $.ajax({
                        url: '@Url.Action("Logout", "Autenticacion")',
                        type: 'POST',
                        headers: {
                            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                window.location.href = response.redirectUrl;
                            } else {
                                alert('Error al cerrar sesión: ' + response.message);
                            }
                        },
                        error: function() {
                            alert('Error al cerrar sesión');
                        }
                    });
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
