@{
    ViewData["Title"] = "Configuración IDs de Portales";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/configuracionportales.css" asp-append-version="true" />

<div class="container-fluid portales-module">
    <div class="row">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="mb-0">
                                <i class="fas fa-link"></i>
                                Configuración IDs de Portales
                            </h4>
                            <small>Gestiona la correspondencia entre las propiedades locales y sus IDs en los diferentes portales inmobiliarios</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabla de Propiedades -->
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-home"></i>
                        Propiedades y sus IDs de Portales
                    </h5>
                </div>
                <div class="card-body portales-table-card">
                    <table id="tablaPropiedades" class="display" cellpadding="0" cellspacing="0" border="0" style="width:100%">
                        <thead>
                            <tr>
                                <th>ID Propiedad</th>
                                <th>Imagen</th>
                                <th>Título</th>
                                <th>Dirección</th>
                                <th>ID TocToc</th>
                                <th>ID ChilePropiedades</th>
                                <th>ID PortalInmobiliario</th>
                                <th>ID Proppit</th>
                                <th>ID PortalRosch</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para configurar IDs de Portales -->
<div class="modal fade" id="modalConfiguracionPortales" tabindex="-1" aria-labelledby="modalConfiguracionPortalesLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalConfiguracionPortalesLabel">
                    <i class="fas fa-link"></i>
                    Configurar IDs de Portales
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="formConfiguracionPortales">
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="idPropiedadModal" name="ID_Propiedad">
                    
                    <!-- Información de la propiedad -->
                    <div class="alert alert-secondary mb-3">
                        <h6><strong>Propiedad:</strong></h6>
                        <div id="infoPropiedadModal">
                            <!-- Se llena dinámicamente -->
                        </div>
                    </div>

                    <!-- Formulario de IDs -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="idChilePropiedades" class="form-label">
                                    <i class="fas fa-map-marker-alt text-danger"></i>
                                    ID Chile Propiedades
                                </label>
                                <input type="text" class="form-control" id="idChilePropiedades" name="id_ChilePropiedades" 
                                       placeholder="Ingrese ID de Chile Propiedades" maxlength="50">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="idPortalInmobiliario" class="form-label">
                                    <i class="fas fa-building text-success"></i>
                                    ID Portal Inmobiliario
                                </label>
                                <input type="text" class="form-control" id="idPortalInmobiliario" name="id_PortalInmobiliario" 
                                       placeholder="Ingrese ID de Portal Inmobiliario" maxlength="50">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="idTocToc" class="form-label">
                                    <i class="fas fa-home text-warning"></i>
                                    ID Toc Toc
                                </label>
                                <input type="text" class="form-control" id="idTocToc" name="id_TocToc" 
                                       placeholder="Ingrese ID de Toc Toc" maxlength="50">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="idProppit" class="form-label">
                                    <i class="fas fa-key text-info"></i>
                                    ID Proppit
                                </label>
                                <input type="text" class="form-control" id="idProppit" name="id_Proppit" 
                                       placeholder="Ingrese ID de Proppit" maxlength="50">
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="mb-3">
                                <label for="idPortalRosch" class="form-label">
                                    <i class="fas fa-star text-primary"></i>
                                    ID Portal Rosch
                                </label>
                                <input type="text" class="form-control" id="idPortalRosch" name="id_PortalRosch" 
                                       placeholder="Ingrese ID de Portal Rosch" maxlength="50">
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>Importante:</strong> Estos IDs son utilizados para sincronizar las estadísticas y datos entre nuestro sistema y los portales externos.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Guardar Configuración
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/configuracionportales.js" asp-append-version="true"></script>
}
