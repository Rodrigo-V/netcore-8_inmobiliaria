@{
    ViewData["Title"] = "Configuración IDs de Portales";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="mb-0">
                                <i class="fas fa-link"></i>
                                Configuración IDs de Portales
                            </h4>
                            <small>Gestiona la correspondencia entre las propiedades locales y sus IDs en los diferentes portales inmobiliarios</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabla de Propiedades -->
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-home"></i>
                        Propiedades y sus IDs de Portales
                    </h5>
                </div>
                <div class="card-body">
                    <table id="tablaPropiedades" class="table table-striped table-bordered" style="width:100%">
                        <thead>
                            <tr>
                                <th>ID Propiedad</th>
                                <th>Imagen</th>
                                <th>Título</th>
                                <th>Dirección</th>
                                <th>ID TocToc</th>
                                <th>ID ChilePropiedades</th>
                                <th>ID PortalInmobiliario</th>
                                <th>ID Proppit</th>
                                <th>ID PortalRosch</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para configurar IDs de Portales -->
<div class="modal fade" id="modalConfiguracionPortales" tabindex="-1" aria-labelledby="modalConfiguracionPortalesLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalConfiguracionPortalesLabel">
                    <i class="fas fa-link"></i>
                    Configurar IDs de Portales
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="formConfiguracionPortales">
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="idPropiedadModal" name="ID_Propiedad">
                    
                    <!-- Información de la propiedad -->
                    <div class="alert alert-secondary mb-3">
                        <h6><strong>Propiedad:</strong></h6>
                        <div id="infoPropiedadModal">
                            <!-- Se llena dinámicamente -->
                        </div>
                    </div>

                    <!-- Formulario de IDs -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="idChilePropiedades" class="form-label">
                                    <i class="fas fa-map-marker-alt text-danger"></i>
                                    ID Chile Propiedades
                                </label>
                                <input type="text" class="form-control" id="idChilePropiedades" name="id_ChilePropiedades" 
                                       placeholder="Ingrese ID de Chile Propiedades" maxlength="50">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="idPortalInmobiliario" class="form-label">
                                    <i class="fas fa-building text-success"></i>
                                    ID Portal Inmobiliario
                                </label>
                                <input type="text" class="form-control" id="idPortalInmobiliario" name="id_PortalInmobiliario" 
                                       placeholder="Ingrese ID de Portal Inmobiliario" maxlength="50">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="idTocToc" class="form-label">
                                    <i class="fas fa-home text-warning"></i>
                                    ID Toc Toc
                                </label>
                                <input type="text" class="form-control" id="idTocToc" name="id_TocToc" 
                                       placeholder="Ingrese ID de Toc Toc" maxlength="50">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="idProppit" class="form-label">
                                    <i class="fas fa-key text-info"></i>
                                    ID Proppit
                                </label>
                                <input type="text" class="form-control" id="idProppit" name="id_Proppit" 
                                       placeholder="Ingrese ID de Proppit" maxlength="50">
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="mb-3">
                                <label for="idPortalRosch" class="form-label">
                                    <i class="fas fa-star text-primary"></i>
                                    ID Portal Rosch
                                </label>
                                <input type="text" class="form-control" id="idPortalRosch" name="id_PortalRosch" 
                                       placeholder="Ingrese ID de Portal Rosch" maxlength="50">
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>Importante:</strong> Estos IDs son utilizados para sincronizar las estadísticas y datos entre nuestro sistema y los portales externos.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Guardar Configuración
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Inicializar DataTable
            var tabla = $('#tablaPropiedades').DataTable({
                processing: true,
                serverSide: true,
                ajax: {
                    url: '@Url.Action("GetData", "ConfiguracionPortales")',
                    type: 'POST'
                },
                columns: [
                    { data: 'ID_Propiedad', name: 'ID_Propiedad' },
                    { 
                        data: null,
                        orderable: false,
                        render: function(data, type, row) {
                            var imagenUrl = row.Url_Imagen || row.Imagen_Propiedad;
                            if (imagenUrl) {
                                return '<img src="' + imagenUrl + '" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px;">';
                            }
                            return '<div class="text-center text-muted"><i class="fas fa-image fa-2x"></i></div>';
                        }
                    },
                    { data: 'Titulo', name: 'Titulo' },
                    { data: 'Direccion', name: 'Direccion' },
                    { data: 'id_TocToc', name: 'id_TocToc', defaultContent: '' },
                    { data: 'id_ChilePropiedades', name: 'id_ChilePropiedades', defaultContent: '' },
                    { data: 'id_PortalInmobiliario', name: 'id_PortalInmobiliario', defaultContent: '' },
                    { data: 'id_Proppit', name: 'id_Proppit', defaultContent: '' },
                    { data: 'id_PortalRosch', name: 'id_PortalRosch', defaultContent: '' },
                    { 
                        data: null, 
                        orderable: false,
                        render: function(data, type, row) {
                            return '<button class="btn btn-primary btn-sm" onclick="configurarPortales(\'' + row.ID_Propiedad + '\')">' +
                                   '<i class="fas fa-cog"></i> Configurar' +
                                   '</button>';
                        }
                    }
                ],
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json'
                },
                order: [[0, 'asc']]
            });

            // Configurar portales
            window.configurarPortales = function(idPropiedad) {
                // Obtener datos de la propiedad desde la tabla
                var datosPropiedad = tabla.rows().data().toArray().find(function(item) {
                    return item.ID_Propiedad === idPropiedad;
                });

                if (datosPropiedad) {
                    // Llenar información de la propiedad
                    $('#idPropiedadModal').val(idPropiedad);
                    $('#infoPropiedadModal').html(
                        '<strong>ID:</strong> ' + datosPropiedad.ID_Propiedad + '<br>' +
                        '<strong>Código:</strong> ' + (datosPropiedad.Codigo_Referencia || 'N/A') + '<br>' +
                        '<strong>Título:</strong> ' + (datosPropiedad.Titulo || 'N/A') + '<br>' +
                        '<strong>Dirección:</strong> ' + (datosPropiedad.Direccion || 'N/A') + '<br>' +
                        '<strong>Comuna:</strong> ' + (datosPropiedad.Comuna || 'N/A')
                    );

                    // Cargar IDs existentes
                    cargarIDsPortales(idPropiedad);

                    // Mostrar modal
                    var modal = new bootstrap.Modal(document.getElementById('modalConfiguracionPortales'));
                    modal.show();
                }
            };

            // Cargar IDs de portales existentes
            function cargarIDsPortales(idPropiedad) {
                $.get('@Url.Action("ObtenerIDsPortales", "ConfiguracionPortales")', { idPropiedad: idPropiedad })
                .done(function(response) {
                    if (response.success && response.data) {
                        $('#idChilePropiedades').val(response.data.id_ChilePropiedades || '');
                        $('#idPortalInmobiliario').val(response.data.id_PortalInmobiliario || '');
                        $('#idTocToc').val(response.data.id_TocToc || '');
                        $('#idProppit').val(response.data.id_Proppit || '');
                        $('#idPortalRosch').val(response.data.id_PortalRosch || '');
                    }
                })
                .fail(function() {
                    alert('Error: No se pudieron cargar los IDs de portales existentes');
                });
            }

            // Guardar configuración
            $('#formConfiguracionPortales').on('submit', function(e) {
                e.preventDefault();
                
                var formData = $(this).serialize();

                $.post('@Url.Action("GuardarIDsPortales", "ConfiguracionPortales")', formData)
                .done(function(response) {
                    if (response.success) {
                        var modalEl = document.getElementById('modalConfiguracionPortales');
                        var modal = bootstrap.Modal.getInstance(modalEl);
                        modal.hide();
                        
                        // Mostrar mensaje de éxito
                        alert('Configuración guardada exitosamente');
                        
                        // Recargar tabla
                        tabla.ajax.reload(null, false);
                    } else {
                        alert('Error al guardar: ' + response.message);
                    }
                })
                .fail(function(xhr, status, error) {
                    alert('Error al guardar la configuración: ' + error);
                });
            });
        });
    </script>
}
